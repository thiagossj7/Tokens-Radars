{
  "name": "radar-tokens-vegeta",
  "displayName": "Radar de Tokens — Vegeta",
  "description": "Muestra tu uso del plan de Claude (sesión 5h y semana 7d) en la barra de estado.",
  "version": "1.0.0",
  "publisher": "kodevo",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "radar.refresh",
        "title": "Radar: Actualizar uso"
      },
      {
        "command": "radar.showPanel",
        "title": "Radar: Mostrar panel"
      },
      {
        "command": "radar.closePanel",
        "title": "Radar: Cerrar panel"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run cp:webview && npm run cp:assets",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "cp:webview": "copyfiles -u 2 \"src/webview/**/*.css\" \"src/webview/**/*.html\" \"src/webview/**/*.js\" out/webview/",
    "cp:assets": "copyfiles -u 1 \"assets/*\" \"out/webview/\""
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "copyfiles": "^2.4.1"
  }
}
